{
  "name": "financial-law-mcp",
  "version": "0.2.0",
  "description": "MCP server for Japanese financial laws — e-Gov API (金商法・資金決済法・貸金業法・銀行法・保険業法 etc.)",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "financial-law-mcp": "dist/index.js"
  },
  "files": [
    "dist/**/*"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/fcukoksan/financial-law-mcp"
  },
  "keywords": [
    "mcp",
    "finance",
    "japan",
    "law",
    "e-gov",
    "claude",
    "kinshō",
    "fsa"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "pdf-parse": "^2.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/pdf-parse": "^1.1.5",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  }
}
